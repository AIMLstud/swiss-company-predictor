# ── PostgreSQL (shared cluster, three databases) ─────────────────────────────
POSTGRES_USER=swiss
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── pgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=admin

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# ── Zefix REST API ────────────────────────────────────────────────────────────
ZEFIX_USERNAME=
ZEFIX_PASSWORD=
ZEFIX_BASE_URL=https://www.zefix.admin.ch/ZefixPublicREST/api/v1

# ── Application database (raw / features / predictions schemas) ───────────────
APP_DB_URL=postgresql+psycopg://swiss:changeme@postgres:5432/app

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_DB_URL=postgresql+psycopg://swiss:changeme@postgres:5432/mlflow
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts
